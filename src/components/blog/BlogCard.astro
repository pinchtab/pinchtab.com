---
import type { BlogPostSummary } from '@/lib/blog';
import Card from '@/components/ui/Card.astro';
import { cn } from '@/lib/utils';

export interface Props {
  post: BlogPostSummary;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const dateLabel = post.pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<Card
  variant="hover"
  padding={compact ? 'md' : 'lg'}
  class={cn(
    'group h-full rounded-2xl border border-brand-border-subtle/15 bg-brand-surface/70 backdrop-blur-sm',
    'hover:-translate-y-1 hover:border-brand-border/45 hover:shadow-[0_24px_64px_rgb(var(--theme-glow-rgb)/0.12)]'
  )}
>
  <a href={`/blog/${post.slug}`} class="flex h-full flex-col gap-5">
    <div class="flex flex-wrap items-center gap-3 text-sm text-brand-text-dim">
      <span>{dateLabel}</span>
      <span aria-hidden="true">•</span>
      <span>{post.readTime}</span>
    </div>

    <div class="space-y-3">
      <h3 class="text-2xl font-semibold tracking-[-0.03em] text-brand-text transition-colors group-hover:text-brand-accent">
        {post.title}
      </h3>
      <p class="max-w-2xl text-base leading-7 text-brand-text-muted">
        {post.description}
      </p>
    </div>

    {post.tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-2 pt-2">
        {post.tags.map((tag) => (
          <span class="rounded-full border border-brand-border-subtle/15 bg-black/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-brand-text-dim">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</Card>
