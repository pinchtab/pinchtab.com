---
import Button from '@/components/ui/Button.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getFeaturedPosts } from '@/lib/blog';

const posts = await getFeaturedPosts(2);
---

{posts.length > 0 && (
  <section class="px-6 py-20 sm:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-4">
          <div class="section-label">Blog</div>
          <h2 class="max-w-2xl text-balance text-4xl font-bold tracking-[-0.04em] text-brand-text sm:text-5xl">
            Notes from the browser trench.
          </h2>
          <p class="text-lg leading-8 text-brand-text-muted">
            Release context, design tradeoffs, weird browser edges, and the occasional field note from building PinchTab.
          </p>
        </div>

        <Button
          href="/blog"
          variant="secondary"
          size="md"
          class="h-12 rounded-[10px] px-6 text-[0.9rem]"
        >
          Read the blog
        </Button>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {posts.map((post) => (
          <BlogCard post={post} compact />
        ))}
      </div>
    </div>
  </section>
)}
