---
import { cn } from '@/lib/utils';

export interface Props {
  agent: string;
  human: string;
  response?: string;
}

const { agent, human, response } = Astro.props;

// Basic syntax highlighting for terminal commands
const highlightCommand = (code: string) => {
  return code
    .split('\n')
    .map((line) => {
      const isComment = line.trim().startsWith('#');
      const escaped = line
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
      
      return `<span class="block ${
        isComment ? 'text-brand-text-dim' : 'text-brand-accent'
      }" data-code-line data-is-comment="${isComment ? 'true' : 'false'}">${escaped}</span>`;
    })
    .join('');
};

const highlightJson = (json: string) => {
  if (!json) return '';
  let pretty = json;
  try {
    pretty = JSON.stringify(JSON.parse(json), null, 2);
  } catch (e) {}

  const tokenRegex = /"(?:\\.|[^"\\])*"|-?\d+(?:\.\d+)?(?:[eE][+\-]?\d+)?|\btrue\b|\bfalse\b|\bnull\b/g;
  
  return pretty.replace(tokenRegex, (match) => {
    let className = 'text-brand-accent';
    if (match.startsWith('"')) {
      // Very crude way to tell if it's a key or value
      className = match.endsWith(':') ? 'text-brand-accent-light' : 'text-brand-green';
    } else if (match === 'true' || match === 'false') {
      className = 'text-brand-blue';
    } else if (match === 'null') {
      className = 'text-brand-red';
    }
    return `<span class="${className}">${match}</span>`;
  });
};

const agentHtml = highlightCommand(agent);
const humanHtml = highlightCommand(human);
const responseHtml = response ? highlightJson(response) : null;
---

<div class="my-10 overflow-hidden rounded-xl border border-white/5 shadow-2xl shadow-black/60 group/terminal relative" data-docs-terminal>
  <div class="flex h-11 items-center gap-4 border-b border-white/5 bg-black/25 px-5">
    <div class="flex gap-1.5 opacity-40 group-hover/terminal:opacity-100 transition-opacity duration-300">
      <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]" aria-hidden="true"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]" aria-hidden="true"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]" aria-hidden="true"></span>
    </div>
    <span class="text-[0.68rem] font-bold tracking-[0.2em] text-brand-text-dim/60">BASH</span>
    <span class="ml-auto text-[0.62rem] font-bold tracking-[0.15em] text-brand-text-dim/40 uppercase">Terminal</span>
  </div>
  
  <div class="relative px-6 py-6">
    <pre class="code-terminal-section overflow-x-auto whitespace-pre font-mono text-[0.85rem] leading-[1.75] text-brand-text-muted m-0 border-0 bg-transparent p-0 text-left shadow-none" data-terminal-content><code data-mode-content="agent" set:html={agentHtml}></code><code data-mode-content="human" set:html={humanHtml}></code></pre>
    
    <button
      type="button"
      class="absolute bottom-4 right-4 flex h-8 min-w-[3rem] items-center justify-center rounded-md border border-brand-accent/30 bg-brand-accent/10 px-2 text-[0.65rem] font-bold tracking-wider text-brand-accent transition-all hover:bg-brand-accent/20 hover:text-brand-accent-light opacity-0 group-hover/terminal:opacity-100"
      data-copy-terminal
      title="Copy to clipboard"
    >
      CP
    </button>
  </div>

  {responseHtml && (
    <div class="border-t border-brand-border-subtle/10 px-6 py-5">
      <div class="mb-3 flex items-center gap-2">
        <div class="h-1.5 w-1.5 rounded-full bg-brand-green/50"></div>
        <span class="text-[0.65rem] font-bold uppercase tracking-[0.15em] text-brand-text-dim">Response</span>
      </div>
      <pre class="code-terminal-section overflow-x-auto whitespace-pre font-mono text-[0.78rem] leading-[1.65] text-brand-text-muted m-0 border-0 bg-transparent p-0 text-left shadow-none"><code set:html={responseHtml}></code></pre>
    </div>
  )}
</div>
