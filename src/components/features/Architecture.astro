---
import CodeTerminal from '@/components/ui/CodeTerminal.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
---

<section>
  <SectionHeading
    label="Architecture"
    title="Simple by design"
    description="One binary. One Chrome. HTTP in, CDP out."
  />

  <CodeTerminal
    tabs={[
      {
        label: 'CLI',
        method: 'cli',
        code: '# Open GitHub in Pinchtab\npinchtab nav https://github.com/pinchtab/pinchtab',
      },
    ]}
    defaultTab="cli"
    terminalLabel="runtime"
  />
</section>
