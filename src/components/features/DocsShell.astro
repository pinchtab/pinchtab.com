---
import ModeSwitch from '@/components/ui/ModeSwitch.astro';
import DocsSidebar from './DocsSidebar.astro';
import DocsToc from './DocsToc.astro';
import DocsRenderer from '@/components/docs/DocsRenderer.astro';
import type { DocsData, DocsPage } from '@/lib/docs/types';

export interface Props {
  docsData: DocsData;
  currentPage: DocsPage;
}

const { docsData, currentPage } = Astro.props;
---

<ModeSwitch />

<DocsSidebar docsData={docsData} currentPage={currentPage} class="hidden xl:flex fixed left-6 top-6 z-40" />
<DocsToc headings={currentPage.headings} class="hidden xl:block fixed right-6 top-6 z-40" />

<div class="w-full px-4 py-6 sm:px-6 lg:px-8">
  <article class="min-w-0 xl:mx-65">
    <div class="p-4 sm:p-8 xl:px-16 max-w-4xl mx-auto">
      <DocsRenderer blocks={currentPage.blocks} />
    </div>
  </article>
</div>

<script is:inline>
  (() => {
    // Terminal Copy Logic
    const terminalContainers = Array.from(document.querySelectorAll('[data-docs-terminal]'));
    terminalContainers.forEach((container) => {
      const copyBtn = container.querySelector('[data-copy-terminal]');
      const terminalContent = container.querySelector('[data-terminal-content]');
      if (!copyBtn || !terminalContent) return;

      copyBtn.addEventListener('click', () => {
        const lines = Array.from(terminalContent.querySelectorAll('span[data-is-comment]'));
        let textToCopy = '';
        if (lines.length > 0) {
          textToCopy = lines
            .filter((l) => l.getAttribute('data-is-comment') !== 'true')
            .map((l) => l.textContent || '')
            .join('\n')
            .trim();
        } else {
          textToCopy = terminalContent.textContent || '';
        }

        if (!textToCopy) return;

        navigator.clipboard.writeText(textToCopy).then(() => {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = 'COPIED';
          copyBtn.classList.add('bg-brand-accent/20', 'text-brand-accent-light');
          setTimeout(() => {
            copyBtn.textContent = originalText;
            copyBtn.classList.remove('bg-brand-accent/20', 'text-brand-accent-light');
          }, 2000);
        });
      });
    });
  })();
</script>
