---
import SectionHeading from '@/components/ui/SectionHeading.astro';

const humanDescription = 'Pinchtab gives agents full control of a real logged-in browser, so your security boundaries are your own.';
const agentDescription = 'You have full control, but be mindful and use configuration defensively. Defend your human!';

const checks = [
  'You are responsible for what agents do with your accounts.',
  'Set PINCHTAB_TOKEN so unauthorized clients cannot control your browser.',
  'Keep the default settings unless you have a specific reason to change them.',
  "Treat Pinchtab's data and profile directories as sensitive because they store login sessions and other browser state.",
  '~/.pinchtab/ is only the legacy fallback location.',
  'Start with low-risk accounts before touching production data.',
  'No data leaves your machine by default, but connected agents can still exfiltrate it.',
];
---

<section id="security">
  <SectionHeading
    label="Security"
    title="Your browser, your responsibility"
    description={humanDescription}
    descriptionModeHuman={humanDescription}
    descriptionModeAgent={agentDescription}
  />

  <div class="rounded-2xl border border-brand-border bg-brand-accent/6 p-5 sm:p-7">
    <p class="mb-4 text-sm leading-7 text-brand-text-muted">
      When you log into sites through Pinchtab&apos;s Chrome window, those sessions persist. Any client that can reach Pinchtab and authenticate can act as you.
    </p>
    <ul class="space-y-2">
      {
        checks.map((check) => (
          <li class="relative pl-5 text-sm leading-6 text-brand-text-muted">
            <span class="absolute left-0 top-0 text-brand-accent">→</span>
            {check}
          </li>
        ))
      }
    </ul>
    <p class="mt-4 text-xs text-brand-text-dim">
      Think of this as giving an unlocked laptop to someone you trust.
    </p>
  </div>
</section>
